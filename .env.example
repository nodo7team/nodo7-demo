# ──────────────────────────────────────────────────────────────
# IPTV PANEL — Variables de entorno
# Copiá este archivo a .env.local para desarrollo
# En Vercel, cargá estas mismas variables en Settings → Environment Variables
# ──────────────────────────────────────────────────────────────

# ── ClickTV (XUI Panel API) ──
XUI_API_KEY=tu_api_key_aqui
XUI_BASE_URL=http://dns.clicktv.online:8080/TbAzTlac/reseller/index.php

# ── Raptor TV (scraping con cookies) ──
RAPTOR_URL=https://ventas.raptorxyz.com
RAPTOR_USER=tu_usuario_raptor
RAPTOR_PASS=tu_password_raptor

# ── Supabase ──
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Autenticación del panel ──
# Generar con: npm run set-pin -- 123456
APP_PIN_HASH=$2a$10$xxxxxxxxxxxxxxxxxxxxxxxxxx
# Cualquier string aleatorio largo (32+ caracteres)
SESSION_SECRET=cambiar_por_un_secreto_largo_y_aleatorio_de_minimo_32_caracteres

# ── Cron (Vercel) ──
# Token para proteger los endpoints de cron. Generar uno aleatorio.
CRON_SECRET=otro_secreto_aleatorio_para_los_cron_jobs
