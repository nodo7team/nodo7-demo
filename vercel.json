{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/sync",
      "schedule": "0 0 * * *"
    }
  ],
  "functions": {
    "app/api/raptor/**/route.ts": {
      "maxDuration": 30
    },
    "app/api/sync/**/route.ts": {
      "maxDuration": 60
    },
    "app/api/cron/**/route.ts": {
      "maxDuration": 60
    }
  }
}
